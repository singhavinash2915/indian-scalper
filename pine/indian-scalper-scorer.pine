// =============================================================================
// Indian Scalper — 8-Factor Scorer (Pine Script v5)
// =============================================================================
// Source of truth: src/strategy/scoring.py in the indian-scalper repo.
// Derived from commit: <update-me-when-changing>
//
// Purpose:
//   Lets you independently verify the bot's scoring engine on any symbol in
//   TradingView. Plots the score 0..8 as a step line + colour-codes the
//   background by regime (score >= 6 green, 4-5 amber, < 4 grey).
//
// Usage:
//   1. TradingView → Pine Editor → paste this file → "Add to chart".
//   2. Pick the symbol + timeframe you want to track. The bot uses 15m.
//   3. Right-panel → Alerts → "Create alert on Indian Scalper Scorer" →
//      condition "score crosses above min_score". TV will email / push
//      when the bot's entry condition would fire.
//
// Tolerances:
//   - pandas-ta and Pine use slightly different initial-value conventions for
//     EMA/RSI/ATR (Pine starts from the first bar; pandas-ta needs warmup).
//     Expect scores to converge after ~100 bars. On a liquid intraday chart
//     the difference is 0/8 vs 1/8 early in the day; negligible once warmed.
//   - RSI, MACD, ADX, ATR, BB, Supertrend, SMA all use the SAME parameters
//     as src/strategy/scoring.py + indicators.py. If you change a threshold
//     in config.yaml, update BOTH this Pine and the Python copy; they're
//     not auto-synced.
//
// Caveats:
//   - Volume data for NSE symbols on TV is T+0 best-effort; the bot uses
//     yfinance which is also delayed. Expect minor volume_surge
//     disagreements on the most recent bar.
//   - VWAP resets at session open. The bot's implementation groups by
//     `df.index.normalize()` (IST midnight); Pine's `ta.vwap` resets at
//     the exchange session start. Both correct, both slightly different
//     on low-volume pre-market bars.
// =============================================================================

//@version=5
indicator(
     title       = "Indian Scalper — 8-Factor Scorer",
     shorttitle  = "Scalper 8/8",
     overlay     = false,
     max_labels_count = 50
 )

// ───── Inputs (kept in sync with config.yaml defaults) ────────────────────────
ema_fast_len   = input.int(5,   "EMA fast length",   group="Strategy")
ema_mid_len    = input.int(13,  "EMA mid length",    group="Strategy")
ema_slow_len   = input.int(34,  "EMA slow length",   group="Strategy")
ema_trend_len  = input.int(50,  "EMA trend length",  group="Strategy")
rsi_len        = input.int(14,  "RSI length",        group="Strategy")
rsi_lo         = input.float(55.0, "RSI entry range low",  group="Strategy")
rsi_hi         = input.float(75.0, "RSI entry range high", group="Strategy")
rsi_hard_block = input.float(78.0, "RSI hard-block threshold", group="Strategy")
adx_len        = input.int(14,  "ADX length",        group="Strategy")
adx_min        = input.float(22.0, "ADX minimum",    group="Strategy")
vol_sma_len    = input.int(20,  "Volume SMA length", group="Strategy")
vol_mult       = input.float(2.0, "Volume surge × SMA", group="Strategy")
bb_len         = input.int(20,  "Bollinger length",  group="Strategy")
bb_std         = input.float(2.0, "Bollinger std",   group="Strategy")
st_len         = input.int(10,  "Supertrend ATR length", group="Strategy")
st_mult        = input.float(3.0, "Supertrend multiplier", group="Strategy")
min_score      = input.int(6,   "Minimum score to enter",
                          tooltip = "Matches config.yaml strategy.min_score",
                          group = "Alerts")

// ───── Indicators ─────────────────────────────────────────────────────────────
ema_fast  = ta.ema(close, ema_fast_len)
ema_mid   = ta.ema(close, ema_mid_len)
ema_slow  = ta.ema(close, ema_slow_len)
ema_trend = ta.ema(close, ema_trend_len)

rsi = ta.rsi(close, rsi_len)

[macd_line, signal_line, hist] = ta.macd(close, 12, 26, 9)
[dip_plus, dip_minus, adx] = ta.dmi(adx_len, adx_len)

vol_sma = ta.sma(volume, vol_sma_len)

[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_len, bb_std)
bb_bw_raw  = (bb_upper - bb_lower) / bb_mid * 100
bb_bw      = na(bb_bw_raw) ? 0.0 : bb_bw_raw
bb_bw_min  = ta.lowest(bb_bw, 20)

[st_line, st_dir] = ta.supertrend(st_mult, st_len)

// Intraday VWAP that resets at session open (matches bot's daily reset).
vwap_ = ta.vwap(hlc3)

// ───── Factor checks — mirror scoring.py line-for-line ───────────────────────
f_ema_stack    = close > ema_fast and ema_fast > ema_mid and ema_mid > ema_slow and close > ema_trend
f_vwap_cross   = close > vwap_ and close[1] <= vwap_[1]
f_macd_cross   = hist > 0 and hist[1] <= 0
f_rsi_entry    = rsi >= rsi_lo and rsi <= rsi_hi
f_adx_trend    = adx >= adx_min
f_vol_surge    = volume >= vol_sma * vol_mult
// Bollinger squeeze → breakout:
// Same heuristic as scoring.py: bandwidth ≥ 1.5× rolling-min over 20 bars,
// currently still expanding, and close above the middle band.
bb_expansion_ratio = bb_bw_min > 0 ? bb_bw / bb_bw_min : 0.0
f_bb_breakout  = bb_expansion_ratio >= 1.5 and bb_bw > bb_bw[5] * 1.1 and close > bb_mid
f_supertrend   = st_dir == -1 and close > st_line   // Pine returns -1 for bullish

// ───── Score + hard block ────────────────────────────────────────────────────
score =
     (f_ema_stack    ? 1 : 0) +
     (f_vwap_cross   ? 1 : 0) +
     (f_macd_cross   ? 1 : 0) +
     (f_rsi_entry    ? 1 : 0) +
     (f_adx_trend    ? 1 : 0) +
     (f_vol_surge    ? 1 : 0) +
     (f_bb_breakout  ? 1 : 0) +
     (f_supertrend   ? 1 : 0)

blocked = rsi > rsi_hard_block
effective_score = blocked ? 0 : score

// ───── Plots ─────────────────────────────────────────────────────────────────
score_col =
     blocked        ? color.new(color.fuchsia, 0) :
     effective_score >= 6 ? color.new(color.green, 0) :
     effective_score >= 4 ? color.new(color.orange, 0) :
                            color.new(color.gray, 0)

plot(effective_score, title="Score", style=plot.style_stepline, linewidth=3,
     color=score_col)

// Threshold line (min_score)
hline(min_score, "min_score threshold", color=color.new(color.aqua, 50),
      linestyle=hline.style_dashed)
hline(6, "strong signal (6/8)", color=color.new(color.green, 70),
      linestyle=hline.style_dotted)
hline(0, "", color=color.new(color.gray, 90))

bgcolor(
     blocked                   ? color.new(color.fuchsia, 85) :
     effective_score >= 6      ? color.new(color.green,   92) :
     effective_score >= 4      ? color.new(color.orange,  94) : na,
     title="Regime background")

// ───── Per-factor breakdown table (top-right of pane) ─────────────────────────
var table t = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 85))

tick(cond) => cond ? "✓" : "·"
cell_col(cond) => cond ? color.new(color.green, 0) : color.new(color.gray, 40)

if barstate.islast
    table.cell(t, 0, 0, "Score",      text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 20))
    table.cell(t, 1, 0, str.tostring(effective_score) + "/8",
               text_color=score_col, text_size=size.small, bgcolor=color.new(color.black, 20))
    table.cell(t, 0, 1, "EMA stack",   text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 1, tick(f_ema_stack),  text_color=cell_col(f_ema_stack),  text_size=size.tiny)
    table.cell(t, 0, 2, "VWAP cross",  text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 2, tick(f_vwap_cross), text_color=cell_col(f_vwap_cross), text_size=size.tiny)
    table.cell(t, 0, 3, "MACD cross",  text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 3, tick(f_macd_cross), text_color=cell_col(f_macd_cross), text_size=size.tiny)
    table.cell(t, 0, 4, "RSI in range", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 4, tick(f_rsi_entry),  text_color=cell_col(f_rsi_entry),  text_size=size.tiny)
    table.cell(t, 0, 5, "ADX >= min",  text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 5, tick(f_adx_trend),  text_color=cell_col(f_adx_trend),  text_size=size.tiny)
    table.cell(t, 0, 6, "Volume surge", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 6, tick(f_vol_surge),  text_color=cell_col(f_vol_surge),  text_size=size.tiny)
    table.cell(t, 0, 7, "BB breakout", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 7, tick(f_bb_breakout), text_color=cell_col(f_bb_breakout), text_size=size.tiny)
    table.cell(t, 0, 8, "Supertrend",  text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 8, tick(f_supertrend), text_color=cell_col(f_supertrend), text_size=size.tiny)
    table.cell(t, 0, 9, "RSI block?",  text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 9, blocked ? "YES" : "no",
               text_color = blocked ? color.new(color.fuchsia, 0) : color.new(color.gray, 30),
               text_size=size.tiny)

// ───── Alerts ────────────────────────────────────────────────────────────────
// Configure once in TV: Alerts panel → select this indicator → condition
// "Entry threshold crossed". Fires when the effective score crosses above
// min_score, which is the same gate the bot uses to place an order.
alertcondition(
     ta.crossover(effective_score, min_score),
     title = "Score crossed entry threshold",
     message = "{{ticker}} {{interval}} score ≥ min_score ({{close}})")

// Extra: hard-block alert so you're aware if the bot refuses a high-score
// setup purely due to RSI > 78.
alertcondition(
     ta.crossover(rsi, rsi_hard_block),
     title = "RSI crossed into hard-block zone",
     message = "{{ticker}} RSI crossed above 78 — bot will not enter even on 8/8")
